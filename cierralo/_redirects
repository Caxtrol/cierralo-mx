# Ciérralo.mx — Reglas de redirección Netlify

# Archivos estáticos — pasan directo
/index.html         /index.html         200
/vendedor.html      /vendedor.html      200
/resena.html        /resena.html        200
/sw.js              /sw.js              200
/manifest.json      /manifest.json      200
/icon-192.png       /icon-192.png       200
/icon-512.png       /icon-512.png       200
/css/*              /css/:splat         200
/js/*               /js/:splat          200

# Raíz — landing pública
/                   /landing.html       200

# App del vendedor — login, se instala como PWA
/app                /index.html         200

# Páginas legales — públicas, sin login
/terminos           /terminos.html      200
/privacidad         /privacidad.html    200
/cancelaciones      /cancelaciones.html 200

# Links de reseña: cierralo.mx/resena/TOKEN
/resena/:token      /resena.html        200

# Perfiles de vendedor: cierralo.mx/antonio-castro
/:slug              /vendedor.html      200
